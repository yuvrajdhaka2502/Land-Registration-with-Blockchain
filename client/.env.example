# Pinata IPFS API Keys
# Sign up at https://app.pinata.cloud → API Keys → New Key → enable pinFileToIPFS
# Copy the values below and save this file as .env in the client/ folder

REACT_APP_PINATA_API_KEY=your_pinata_api_key_here
REACT_APP_PINATA_SECRET_KEY=your_pinata_secret_api_key_here

# Oracle Backend URL (Express server on port 3001)
REACT_APP_ORACLE_URL=http://localhost:3001
