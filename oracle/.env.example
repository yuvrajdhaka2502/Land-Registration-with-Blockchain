# Oracle Backend Configuration
# Copy this file to .env and fill in the values

# Account #1's private key from `npm run node` output
# (the second account listed — Account #1, not Account #0)
ORACLE_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d

# RPC URL for the Hardhat local network
RPC_URL=http://127.0.0.1:8545

# Port for the oracle server (React uses 3000)
ORACLE_PORT=3001
